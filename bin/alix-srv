#!/usr/bin/env python3

import redis
import time
import alix.core as alix
from alix.core import Alix

def run():
	runningServices = {}
	r = redis.StrictRedis()
	p = r.pubsub()
	p.subscribe('alix:cmd')

	exit = False
	while not exit:
		event = p.get_message()
		if event and event['type'] == 'message':
			data = event['data']
			print(f'cmd: {data}')
			data = data.split()
			cmd = data[0].decode('utf-8')
			if cmd == 'stopServer':
				#stop all running services
				for svcName in runningServices.keys():
					#stop the service
					svc = runningServices[svcName]
					svc.stop()
					#remove from running services list
					runningServices.pop(svcName)
				exit = True
			elif cmd == 'startService':
				svcName = data[1].decode('utf-8')
				#start the service
				svc = alix.start(svcName)
				#add to running services list
				runningServices[svcName] = svc
			elif cmd == 'stopService':
				svcName = data[1].decode('utf-8')
				if svcName in runningServices:
					#stop the service
					svc = runningServices[svcName]
					svc.stop()
					#remove from running services list
					runningServices.pop(svcName)
			elif cmd == 'restartService':
				svcName = data[1].decode('utf-8')
				if svcName in runningServices:
					#stop the service
					svc = runningServices[svcName]
					svc.stop()
					#remove from running services list
					runningServices.pop(svcName)
				#start the service
				svc = alix.start(svcName)
				#add to running services list
				runningServices[svcName] = svc
			elif cmd == 'restartAllServices':
				for svcName in runningServices.keys():
					svcName = svcName.decode('utf-8')
					svc = runningServices[svcName]
					if svc.isAlive:
						alix.stop(svcName)
						alix.start(svcName)
		time.sleep(0.01)

run()
