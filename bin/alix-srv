#!/usr/bin/env python3

import redis
import time
import alix.core as alix
from alix.core import Alix

def run():
	runningServices = {}
	r = redis.StrictRedis()
	p = r.pubsub()
	p.subscribe('alix:cmd')

	exit = False
	while not exit:
		event = p.get_message()
		if event and event['type'] == 'message':
			data = event['data']
			print(f'cmd: {data}')
			data = data.split()
			cmd = data[0].decode('utf-8')
			if cmd == 'stopServer':
				#stop all running services
				for svcName in runningServices.keys():
					svc = runningServices[svcName]
					if svc.isAlive: svc.stop()	
				exit = True
			elif cmd == 'startService':
				#start the service
				svcName = data[1].decode('utf-8')
				svc = alix.start(svcName)
				if svcName not in runningServices: 
					runningServices[svcName] = svc
			elif cmd == 'stopService':
				#stop the service
				svcName = data[1].decode('utf-8')
				if svcName in runningServices:
					svc = runningServices[svcName]
					svc.stop()
			elif cmd == 'restartService':
				svcName = data[1]
				if svcName in runningServices:
					svc = runningServices[svcName]
					svc.stop()
				svc = alix.start(svcName)
				if svcName not in runningServices: 
					runningServices[svcName] = svc
			elif cmd == 'restartAllServices':
				for svcName in runningServices.keys():
					svc = runningServices[svcName]
					if svc.isAlive:
						alix.stop(svcName)
						alix.start(svcName)
		time.sleep(0.01)

run()
